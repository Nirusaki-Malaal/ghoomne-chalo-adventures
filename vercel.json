{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/statics/(.*)",
      "dest": "/statics/$1"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "headers": [
    {
      "source": "/statics/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
